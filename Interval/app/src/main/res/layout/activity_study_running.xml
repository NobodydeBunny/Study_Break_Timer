<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Study_Running"
    android:background="@color/background">

    <TextView
        android:id="@+id/titletxt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:fontFamily="@font/interfont"
        android:letterSpacing="0.3"
        android:text="INTERVAL"
        android:textColor="@color/blueGrey"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/sessionnametitle"
        android:layout_width="300dp"
        android:layout_height="30dp"
        android:layout_marginTop="84dp"
        android:fontFamily="@font/interfont"
        android:gravity="center"
        android:letterSpacing="0.1"
        android:text="STUDY SESSION"
        android:textColor="@color/muteIndigo"
        android:textFontWeight="700"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/studyfocusing"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="124dp"
        android:fontFamily="@font/interfont"
        android:gravity="center"
        android:letterSpacing="0.1"
        android:text="FOCUSING"
        android:textColor="@color/primary"
        android:textFontWeight="700"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/studycircularProgress"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_marginTop="160dp"
        app:indicatorColor="@color/secondary"
        app:indicatorInset="0dp"
        app:indicatorSize="250dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:trackColor="@color/primary"
        app:trackThickness="2dp" />

    <TextView
        android:id="@+id/studytimerText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="25:00"
        android:textColor="@color/muteIndigo"
        android:textSize="50sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/studycircularProgress"
        app:layout_constraintEnd_toEndOf="@id/studycircularProgress"
        app:layout_constraintStart_toStartOf="@id/studycircularProgress"
        app:layout_constraintTop_toTopOf="@id/studycircularProgress"
        app:layout_constraintVertical_bias="0.500" />

    <TextView
        android:id="@+id/studysessionname"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/interfont"
        android:letterSpacing="0.1"
        android:layout_marginTop="12dp"
        android:text="Study Session"
        android:textColor="@color/blueGrey"
        app:layout_constraintEnd_toEndOf="@+id/studycircularProgress"
        app:layout_constraintHorizontal_bias="0.493"
        app:layout_constraintStart_toStartOf="@+id/studycircularProgress"
        app:layout_constraintTop_toBottomOf="@+id/studytimerText" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="60dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">


        <ImageButton
            android:id="@+id/btnStop"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="40dp"
            android:background="@drawable/bg_circle_outline"
            android:contentDescription="Stop"
            android:scaleType="centerInside"
            android:src="@drawable/ic_cancel"
            app:tint="@color/grey_hint" />

        <ImageButton
            android:id="@+id/btnPauseStart"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_circle_primary"
            android:contentDescription="Pause"
            android:scaleType="centerInside"
            android:src="@drawable/ic_pause"
            app:tint="@android:color/white" />

        <ImageButton
            android:id="@+id/btnSkip"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="40dp"
            android:background="@drawable/bg_circle_outline"
            android:contentDescription="Skip"
            android:scaleType="centerInside"
            android:src="@drawable/ic_skip"
            app:tint="@color/blueGrey" />

    </LinearLayout>

    <TextView
        android:id="@+id/textView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/interfont"
        android:gravity="center"
        android:text="“If you can’t do something, then don’t. \nFocus on what you can do.”"
        android:textColor="@color/blueGrey"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.532"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.7" />


</androidx.constraintlayout.widget.ConstraintLayout>